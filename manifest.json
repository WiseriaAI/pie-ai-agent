{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extension_name__",
  "version": "1.1.0",
  "description": "__MSG_extension_description__",
  "key": "",
  "permissions": ["activeTab", "sidePanel", "storage", "tabs", "tabGroups", "scripting", "debugger", "webNavigation", "offscreen", "downloads", "identity", "alarms", "notifications"],
  "host_permissions": [
    "<all_urls>",
    "https://account.pie.chat/*",
    "https://api.pie.chat/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://api.minimaxi.com/*",
    "https://open.bigmodel.cn/*",
    "https://dashscope.aliyuncs.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://token-plan-cn.xiaomimimo.com/*",
    "https://api.moonshot.ai/*",
    "https://api.moonshot.cn/*",
    "https://api.stepfun.com/*",
    "https://api.kimi.com/*",
    "https://api.xiaomimimo.com/*",
    "https://api.tavily.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["liteparse.wasm", "sql-wasm.wasm", "src/offscreen/pdf-parser.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open Pie"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-entry.ts"],
      "run_at": "document_idle",
      "all_frames": false,
      "match_origin_as_fallback": false
    }
  ],
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "commands": {
    "quote-selection": {
      "description": "Add current text selection as a Pie quote (set hotkey at chrome://extensions/shortcuts)"
    }
  }
}
